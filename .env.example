# ─── API base URL (pick ONE approach) ───────────────────────────────────────
#
# Option A — named preset (see src/config/api.js → API_ENVIRONMENTS):
#   REACT_APP_API_ENV=local
#   REACT_APP_API_ENV=production
#
# Option B — full URL (overrides REACT_APP_API_ENV):
#   REACT_APP_API_BASE_URL=https://backend-gig.aameego.com/api
#
# Default (no .env): https://backend-gig.aameego.com/api
#
# Local development — use .env.local (gitignored):
#   REACT_APP_API_ENV=local
#   REACT_APP_API_BASE_URL=http://localhost:5001/api
#
# Restart `npm start` after changing env files.
